# API auth used by this gateway (not Gemini key)
PASSWORD=your_gateway_password

# Optional: dashboard config password, defaults to PASSWORD if omitted
WEB_PASSWORD=your_dashboard_password

# Timezone
TZ=Asia/Shanghai

# Comma-separated Gemini API keys
GEMINI_API_KEYS=AIzaSy_xxx,AIzaSy_yyy

# Upstream Gemini-compatible base URL
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

# Persistence
ENABLE_STORAGE=true
STORAGE_DIR=/hajimi/settings/

# Rate limits
MAX_REQUESTS_PER_MINUTE=30
MAX_REQUESTS_PER_DAY_PER_IP=600

# Obfuscation
RANDOM_STRING=true
RANDOM_STRING_LENGTH=5

# Concurrency
CONCURRENT_REQUESTS=1
INCREASE_CONCURRENT_ON_FAILURE=0
MAX_CONCURRENT_REQUESTS=3

# Search mode
SEARCH_MODE=false
SEARCH_PROMPT=（使用搜索工具联网搜索，需要在content中结合搜索内容）

# Vertex
ENABLE_VERTEX=false
GOOGLE_CREDENTIALS_JSON=''
ENABLE_VERTEX_EXPRESS=false
VERTEX_EXPRESS_API_KEY=
